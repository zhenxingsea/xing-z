    <content><![CDATA[<h2 id="替换内容"><a href="#替换内容" class="headerlink" title="替换内容"></a>替换内容</h2><figure class="highlight plaintext"><table><tr><td class="code"><pre><span class="line">sed &#x27;s/aaa/bbb/g&#x27; file-path</span><br></pre></td></tr></table></figure>

<h2 id="查找开始与结束"><a href="#查找开始与结束" class="headerlink" title="查找开始与结束"></a>查找开始与结束</h2><figure class="highlight plaintext"><table><tr><td class="code"><pre><span class="line">sed -n &#x27;/10:00:00/,/12:00:00/p&#x27; test.log</span><br></pre></td></tr></table></figure>

<h2 id="查找内容"><a href="#查找内容" class="headerlink" title="查找内容"></a>查找内容</h2><figure class="highlight plaintext"><table><tr><td class="code"><pre><span class="line">grep -nr “keyword” ./</span><br></pre></td></tr></table></figure>]]></content>
